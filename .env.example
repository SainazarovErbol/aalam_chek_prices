# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID Google Таблицы (из ссылки: docs.google.com/spreadsheets/d/ВОТ_ЭТО/edit)
SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Путь к файлу credentials.json (сервисный аккаунт Google)
GOOGLE_CREDENTIALS_FILE=credentials.json

# URL мини-приложения (сканер штрихкода). Должен быть HTTPS.
# Пример: https://username.github.io/aalam_chek_prise/webapp/
WEBAPP_URL=

# Интервал автообновления данных из таблицы (в минутах)
REFRESH_INTERVAL_MIN=30

# ID пользователей Telegram, которым разрешён доступ (через запятую)
# Оставьте пустым, чтобы разрешить всем. Узнать ID: @userinfobot
ALLOWED_USER_IDS=
